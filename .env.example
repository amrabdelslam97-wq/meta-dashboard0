# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of external origins allowed to call the API.
# Leave empty to keep the API closed to cross-origin requests (the bundled
# dashboard is served from the same origin and doesn't need this set).
ALLOWED_ORIGINS=

# Meta API — obtain from https://developers.facebook.com/apps
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v21.0

# Database
DB_PATH=./data/meta_ads.db

# Token encryption — REQUIRED. Meta access tokens are encrypted at rest
# (AES-256-GCM) and the server refuses to start without this key.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your_64_character_hex_key_here
